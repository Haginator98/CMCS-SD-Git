Powershell: 
Install-Module -Name ExchangeOnlineManagement -Force -Scope CurrentUser
Import-Module ExchangeOnlineManagement
Connect-ExchangeOnline -UserPrincipalName epostadresse@dittdomene.no

#Sett Alias på bruker
Set-Mailbox epostadresse@dittdomene.no -EmailAddresses @{Add='dinbruker@domain.com'}
 
#Legge til DL på bruker
Add-DistributionGroupMember -Identity distribusjon@domain.no -Member "epostadresse@dittdomene.no"

#Fjerne DL på bruker
Remove-DistributionGroupMember -Identity distribusjon@domain.no -Member "epostadresse@dittdomene.no"

#sjekk/endre møterom visibility

#Set-MailboxFolderPermission
#[-Identity] <mailboks det gjelder>
#-User <bruker som skal ha tilgang>
#AvailabilityOnly: View only availability data
#LimitedDetails: View availability data with subject and location
# https://learn.microsoft.com/en-us/powershell/module/exchange/set-mailboxfolderpermission?view=exchange-ps

Get-MailboxFolderPermission -Identity epostadresse@dittdomene.no:\Calendar

Set-MailboxFolderPermission -Identity epostadresse@dittdomene.no:\Calendar -User Default -AccessRights LimitedDetails

#Se hva kalender heter
Get-MailboxFolderStatistics -Identity epostadresse@dittdomene.no | Where-Object {$_.FolderType -eq "Calendar"}

#Legge til eier på DL
Set-DistributionGroup -Identity "NavnPåDistribusjonsliste" -ManagedBy "brukernavn@dittdomene.no"

#Opprette DL
New-DistributionGroup -Name "Navn på distribusjonsliste" -Alias "AliasNavn" -PrimarySmtpAddress "epostadresse@dittdomene.no" -Members "bruker1@dittdomene.no", "bruker2@dittdomene.no"

#Sjekke eier av alias
Get-Mailbox -Identity "epostadresse@dittdomene.no"