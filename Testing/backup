    elif game_state == "between_rounds":
         # Calculate time until next wave can start automatically, or show manual start prompt
         time_since_wave_end = current_time - wave_complete_time
         time_until_next = max(0, TIME_BETWEEN_WAVES - time_since_wave_end)
         start_prompt_text = ""
         if time_until_next > 0:
              start_prompt_text = f"Next wave in: {time_until_next / 1000:.1f}s"
