                 print("Cancelling placement.")
                 game_state = "between_rounds" # Return to between rounds state
            # --- Start Wave Manually --- (Example: Press SPACE)
            elif event.key == pygame.K_SPACE and game_state == "between_rounds":
                 # Check if enough time has passed since last wave (optional manual start)
                 # Or just start immediately on key press
                 print(f"Starting Round {current_round}, Wave {current_wave_index + 1}")

                 # --- Start Wave Logic ---
                 # Check if current_round exists
                 if current_round -1 < len(ROUNDS_DATA):
                     current_round_data = ROUNDS_DATA[current_round - 1]
                     # Check if current_wave_index exists for this round
                     if current_wave_index < len(current_round_data):
                         current_wave_data = current_round_data[current_wave_index]
                         enemies_left_to_spawn = current_wave_data.get('count', 0)
                         # TODO: Use 'type' from wave_data if different enemy types exist
                         last_spawn_time = current_time # Ready to spawn immediately (or add delay)
                         game_state = "wave_active"
                     else:
                         # This shouldn't happen if logic is correct, but handle anyway
                         print("Error: Invalid wave index.")
                         # Potentially game over or go back to between rounds?
                 else:
                     print("Game Complete! (No more rounds defined)")
                     # game_state = "game_over" # Implement game over state


        # --- Mouse Clicks --- (Placement Logic)
        if event.type == pygame.MOUSEBUTTONDOWN:
            if game_state == "placing_tower":
                if event.button == 1: # Left
                    if is_placement_valid(mouse_pos, TOWER_WIDTH, TOWER_HEIGHT, all_towers):
                        if player_gold >= TOWER_COST:
                            new_tower = Tower(mouse_pos, TOWER_IMAGE_FILE)
                            all_towers.append(new_tower)
                            player_gold -= TOWER_COST
                            print(f"Placed tower. Gold: {player_gold}")
                            game_state = "between_rounds" # Go back to between rounds after placement
                        else: print("Not enough gold.")
                    else: print("Invalid location.")
                elif event.button == 3: # Right
                    print("Cancelling placement.")
                    game_state = "between_rounds"

    # --- Game Logic Updates ---

    # Update only if game is active (wave or placing)
    if game_state == "wave_active" or game_state == "placing_tower":
        # Move enemies
        for enemy in all_enemies:
            enemy.move()

        # Update towers (targeting, shooting)
        for tower in all_towers:
            tower.update(current_time, all_enemies)

    # --- Spawning Logic --- (Only during active wave)
    if game_state == "wave_active":
        if enemies_left_to_spawn > 0 and (current_time - last_spawn_time >= TIME_BETWEEN_SPAWNS):
            # Spawn next enemy
            # TODO: Use type from wave data if implemented
            new_enemy = Enemy(enemy_path, ENEMY_IMAGE_FILE)
            all_enemies.append(new_enemy)
            enemies_left_to_spawn -= 1
            last_spawn_time = current_time
            print(f"Spawned enemy. Remaining in wave: {enemies_left_to_spawn}")


    # --- Cleanup Dead Enemies --- (Always run cleanup)
    living_enemies = []
    for enemy in all_enemies:
        if enemy.is_alive:
            living_enemies.append(enemy)
    all_enemies = living_enemies


