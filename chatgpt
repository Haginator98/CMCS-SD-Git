# Koble til Microsoft Graph med nødvendige rettigheter
Connect-MgGraph -Scopes "AuditLog.Read.All", "User.Read.All"

# Sett brukerens e-post eller UPN
$UserUPN = "bruker@domene.com"

# Hent audit logs for lisensendringer
$logs = Get-MgAuditLogDirectoryAudit -Filter "activityDisplayName eq 'Change user license' and initiatedBy/user/userPrincipalName eq '$UserUPN'" -All

# Vis detaljer
$logs | Select-Object ActivityDateTime, LoggedByService, Result, TargetResources